{
	"name": "Semantic Forms Select",
	"version": "5.0.0",
	"author": [
		"Jason Zhang",
		"James Hong Kong",
		"Toni Hermoso Pulido",
		"Thomas Mulhall",
		"Alexander Gesinn",
		"[https://github.com/SemanticMediaWiki/SemanticFormsSelect/graphs/contributors ...]"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:SemanticFormsSelect",
	"descriptionmsg": "sfs-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "semantic",
	"requires": {
		"MediaWiki": ">= 1.43",
		"extensions": {
			"SemanticMediaWiki": ">= 7.0",
			"PageForms": ">= 6.0.6"
		}
	},
	"AutoloadNamespaces": {
		"SFS\\": "src/"
	},
	"config": {
		"SF_Select_debug": {
			"value": false
		}
	},
	"APIModules": {
		"sformsselect": "SFS\\ApiSemanticFormsSelect"
	},
	"MessagesDirs": {
		"SemanticFormsSelect": [
			"i18n"
		]
	},
	"ResourceFileModulePaths": {
		"localBasePath": "res",
		"remoteExtPath": "SemanticFormsSelect/res"
	},
	"ResourceModules": {
		"ext.sfs": {
			"scripts": [
				"pf.originalValueLookup.js",
				"sfs.js",
				"index.js"
			],
			"styles": [
				"select2.css"
			],
			"dependencies": [
				"ext.pageforms.main",
				"ext.pageforms.select2"
			]
		}
	},
	"Hooks": {
		"ParserFirstCallInit": [
			"SFS\\Hooks::onSemanticFormsSelectSetup"
		]
	},
	"manifest_version": 2
}
